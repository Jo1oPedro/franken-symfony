FROM node:20-alpine

ARG UID=1000
ARG GID=1000

# node:alpine ships a default "node" user at uid 1000. Re-create as "app"
# matching the host UID/GID so bind-mounted files keep host ownership.
RUN set -ex && \
    deluser --remove-home node 2>/dev/null || true && \
    (getent group ${GID} >/dev/null || addgroup -g ${GID} app) && \
    adduser -S -D -u ${UID} -G "$(getent group ${GID} | cut -d: -f1)" -s /bin/sh -h /home/app app && \
    mkdir -p /app && chown -R ${UID}:${GID} /app

WORKDIR /app

COPY --chown=${UID}:${GID} package.json package-lock.json* ./

USER app

RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]
